rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /games/{gameId} {
      allow read: if request.auth != null;

      // Create a lobby: you are player 1 (black), black moves first.
      allow create: if request.auth != null
        && request.resource.data.players["1"] == request.auth.uid
        && request.resource.data.status == "waiting"
        && request.resource.data.turn == 1
        && request.resource.data.turnUid == request.auth.uid;

      allow update: if request.auth != null && (
        // Join an open lobby as player 2.
        (resource.data.status == "waiting"
          && resource.data.players["2"] == null
          && request.resource.data.players["2"] == request.auth.uid
          && request.resource.data.players["1"] == resource.data.players["1"]
          && request.resource.data.status == "active")
        ||
        // Move or pass: only the player whose turn it is; seats never change.
        (resource.data.status == "active"
          && request.auth.uid == resource.data.turnUid
          && request.resource.data.players["1"] == resource.data.players["1"]
          && request.resource.data.players["2"] == resource.data.players["2"])
      );
    }
  }
}
