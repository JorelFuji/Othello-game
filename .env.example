# OPTIONAL. Project values for othella-flutter are already baked into src/firebase.js,
# so you only need this file if you prefer keeping keys out of committed source.
# Copy to .env and fill the two values from:
#   Firebase console > Project settings > Your apps > (Web app) SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
# These already default correctly; only set to override:
VITE_FIREBASE_AUTH_DOMAIN=othella-flutter.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=othella-flutter
VITE_FIREBASE_STORAGE_BUCKET=othella-flutter.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=868703065049
